/* CSP (Content Security Policy) robusta e HSTS */
/* Zero Trust */
/* Permite Leaflet, OSM e Netlify Identity - Bloqueia resto */
/* O Netlify injecta certas coisas da Identity, por isso incluimos o cdn.jsdelivr.net para o widget */
/* frame-ancestors 'none' evita clickjacking */
/* sem 'unsafe-eval' e 'unsafe-inline' para scripts */

/* No localhost o Vite requer algumas permissões inline, mas para prod focamos estritamente */
/* As permissões de map tiles requerem connect-src para OSM */
/* identity.netlify.com deve constar aqui */

/* As regras abaixo são aplicadas em todos os paths e assets /* */
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://identity.netlify.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://*.netlify.com https://identity.netlify.com; frame-ancestors 'none';
*/

/* O Netlify processa o cabeçalho base abaixo: */
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://identity.netlify.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://*.netlify.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none';
*/
